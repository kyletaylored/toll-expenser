VITE_APP_URL=https://my-worker.cfdomain.workers.dev

# Datadog sourcemap upload — used by @datadog/vite-plugin at build time (not embedded in bundle)
# Get these from Datadog > Organization Settings > API Keys / Application Keys
DD_API_KEY=
DD_APP_KEY=
# Set to 'false' only when deploying to production (deploy workflow sets this automatically)
DD_SOURCEMAPS_DRY_RUN=true

# Datadog RUM — get these from Datadog > UX Monitoring > Add New Application
VITE_DD_RUM_APPLICATION_ID=
VITE_DD_RUM_CLIENT_TOKEN=
VITE_DD_SITE=datadoghq.com
VITE_DD_ENV=prod
VITE_DD_SERVICE=toll-expenser
VITE_DD_VERSION=0.0.1
VITE_DD_SESSION_SAMPLE_RATE=100
VITE_DD_SESSION_REPLAY_SAMPLE_RATE=100
VITE_DD_DEFAULT_PRIVACY_LEVEL=mask-user-input
