/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "toll-expenser",
	"main": "src/index.ts",
	"compatibility_date": "2026-02-25",
	"observability": {
		"enabled": true,
		"logs": {
			"enabled": true,
			"invocation_logs": true
		},
		"traces": {
			"enabled": true
		}
	},
	"compatibility_flags": [
		"nodejs_compat"
	],
	/**
	 * Datadog OTEL — set DD_API_KEY secret to enable all three signals (traces, metrics, logs).
	 * DD_API_KEY is a secret:  wrangler secret put DD_API_KEY
	 * DD_OTLP_SITE is a var:   change to "datadoghq.eu" for the EU region
	 */
	"vars": {
		"DD_OTLP_SITE": "datadoghq.com"
	},
	/**
	 * Static Assets — React SPA built to ./dist by Vite
	 * https://developers.cloudflare.com/workers/static-assets/binding/
	 */
	"assets": {
		"directory": "./dist/",
		"binding": "ASSETS",
		"not_found_handling": "single-page-application"
	}
}